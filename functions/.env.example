# Copy to functions/.env and fill in — .env is gitignored, never commit it.
# Dev-only approach: these deploy as plaintext env vars on the functions.
# Prod should use Secret Manager instead (see README).
NOTION_API_TOKEN=
NOTION_WEBHOOK_VERIFICATION_TOKEN=placeholder-until-webhook-handshake
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
